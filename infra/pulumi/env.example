# Pulumi environment variables (local development only)

# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Pulumi Configuration
# Leave empty for interactive passphrase prompt, or set a passphrase for automation
PULUMI_CONFIG_PASSPHRASE=

# Control Plane URL (set in Pulumi config, not env)
# Use: pulumi config set controlPlaneApiUrl https://your-control-plane.example.com
