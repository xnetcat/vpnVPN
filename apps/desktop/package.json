{
  "name": "@vpnvpn/desktop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:vite": "vite --port 5173 --strictPort",
    "dev:tauri": "tauri dev",
    "dev": "concurrently --kill-others --names \"vite,tauri\" --prefix-colors \"cyan,magenta\" \"bun run dev:vite\" \"bun run dev:tauri\"",
    "build:web": "vite build",
    "build:daemon": "cd daemon && cargo build --release",
    "build:daemon:debug": "cd daemon && cargo build",
    "build:tauri": "bun run build:daemon && cd src-tauri && cargo tauri build",
    "build": "bun run build:web && bun run build:tauri",
    "build:release": "bun run build:web && bun run build:daemon && cd src-tauri && cargo tauri build --release",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "biome lint . && cd src-tauri && cargo fmt --check && cd ../daemon && cargo fmt --check",
    "format": "biome format --write . && cd src-tauri && cargo fmt && cd ../daemon && cargo fmt"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.11",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-deep-link": "^2.4.3",
    "@tauri-apps/plugin-shell": "^2.3.3",
    "@trpc/client": "^11.7.2",
    "@trpc/react-query": "^11.7.2",
    "lucide-react": "^0.555.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-simple-maps": "^3.0.0",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-simple-maps": "^3.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "jsdom": "^27.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
