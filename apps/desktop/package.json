{
  "name": "@vpnvpn/desktop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:web": "vite",
    "dev:tauri": "tauri dev --dev-url http://localhost:5173 --no-dev-server",
    "dev": "bun run dev:web & bun run dev:tauri",
    "build:web": "vite build",
    "build:tauri": "tauri build",
    "build": "bun run build:web && bun run build:tauri",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "biome lint . && cd src-tauri && cargo fmt --check",
    "format": "biome format . && cd src-tauri && cargo fmt"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^27.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
