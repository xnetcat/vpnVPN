{
  "productName": "vpnVPN Desktop",
  "version": "0.1.0",
  "identifier": "com.vpnvpn.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "vpnVPN Desktop",
        "width": 900,
        "height": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["vpnvpn"]
      }
    },
    "shell": {
      "open": true
    }
  }
}
