# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vpnvpn"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# OAuth Providers
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email / Resend (for magic links + notifications)
# EMAIL_SERVER is not used when sending via Resend, but kept for compatibility.
EMAIL_SERVER=""
EMAIL_FROM="noreply@vpnvpn.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_BASIC="price_..."
STRIPE_PRICE_ID_PRO="price_..."
STRIPE_PRICE_ID_ENTERPRISE="price_..."

# Resend (Email magic links + notifications)
RESEND_API_KEY="re_..."

# Control Plane API
CONTROL_PLANE_API_URL="https://api.vpnvpn.com"
CONTROL_PLANE_API_KEY="your-control-plane-api-key"
NEXT_PUBLIC_API_BASE_URL="https://api.vpnvpn.com"

# WireGuard Configuration (Optional - for config generation)
NEXT_PUBLIC_WG_ENDPOINT="vpn.vpnvpn.com:51820"
NEXT_PUBLIC_WG_SERVER_PUBLIC_KEY="server-public-key-here"

# AWS (Optional - if using AWS features)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
