{
  "name": "@vpnvpn/control-plane",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "rm -rf dist && bun build src/index.ts --target=node --outfile=dist/index.mjs && bun build src/lambda.ts --target=node --outfile=dist/lambda/lambda.mjs --minify --external @prisma/client",
    "build:lambda": "bun build src/lambda.ts --target=node --outfile=dist/lambda/lambda.mjs --minify --external @prisma/client",
    "start": "node dist/index.mjs",
    "lint": "biome lint .",
    "test": "vitest run",
    "format": "biome format --write .",
    "docker:build": "docker build -t vpnvpn/control-plane -f services/control-plane/Dockerfile .."
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "fastify": "^5.1.0",
    "@vpnvpn/db": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/aws-lambda": "^8.10.145",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
