// Prisma schema for Auth.js (NextAuth) + Stripe subscriptions + control plane

generator client {
  provider      = "prisma-client-js"
  // Include Linux ARM64 + OpenSSL 3.0.x engine for Docker runtime, alongside native.
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(cuid())
  name              String?
  email             String?        @unique
  emailVerified     DateTime?
  image             String?
  stripeCustomerId  String?
  role              String         @default("user")

  accounts          Account[]
  sessions          Session[]
  subscriptions     Subscription[]
  notificationPreferences NotificationPreferences?
  devices           Device[]
  vpnPeers          VpnPeer[]

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  oauth_token_secret String?
  oauth_token        String?
  refresh_token_expires_in Int?

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String   @unique
  priceId              String
  status               String
  tier                 String   @default("basic")
  currentPeriodEnd     DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
}

model NotificationPreferences {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  marketing     Boolean  @default(true)
  transactional Boolean  @default(true)
  security      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Device {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  publicKey       String   @unique
  machineId       String?  // Unique identifier for the physical device
  serverId        String?
  status          String   @default("pending") // "pending" | "active"
  lastConnectedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([userId, machineId])
}

// Control plane: VPN servers, peers, tokens, metrics

model VpnServer {
  id        String     @id
  publicIp  String?
  metadata  Json?
  status    String
  lastSeen  DateTime

  peers     VpnPeer[]
  metrics   VpnMetric[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model VpnPeer {
  publicKey String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  serverId  String?
  server    VpnServer? @relation(fields: [serverId], references: [id])

  allowedIps String[]
  country    String?
  region     String?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([userId])
}

model VpnToken {
  token      String   @id
  label      String
  createdAt  DateTime @default(now())
  usageCount Int      @default(0)
  active     Boolean  @default(true)
}

model VpnMetric {
  id        String    @id @default(cuid())
  serverId  String
  server    VpnServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
  timestamp DateTime  @default(now())

  cpu        Float?
  memory     Float?
  activePeers Int?
  region     String?

  @@index([serverId, timestamp])
}

// Short-lived desktop login codes used to link the vpnVPN desktop app without
// relying on OS-level deep link handling.
model DesktopLoginCode {
  id         String   @id @default(cuid())
  email      String
  code       String
  url        String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([email, code])
  @@index([expiresAt])
}



