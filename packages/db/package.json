{
  "name": "@vpnvpn/db",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate --schema prisma/schema.prisma",
    "migrate:dev": "DATABASE_URL=postgresql://postgres:password@localhost:5432/vpnvpn prisma migrate dev --schema prisma/schema.prisma",
    "lint": "biome lint .",
    "test": "vitest run --passWithNoTests",
    "format": "biome format --write ."
  },
  "main": "./src/client.ts",
  "module": "./src/client.ts",
  "types": "./src/client.ts",
  "dependencies": {
    "@prisma/client": "^5.19.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "prisma": "^5.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
