{
  "name": "vpnvpn-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.1.38",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:stack": "cd local && docker compose watch",
    "dev:desktop": "cd apps/desktop && bun run dev",
    "dev:desktop:wait": "sh -c 'echo \"Waiting for web-app on http://localhost:3000...\"; until curl -sSf http://localhost:3000/desktop >/dev/null 2>&1; do sleep 2; done; echo \"web-app is up; starting desktop...\"; cd apps/desktop && bun run dev'",
    "dev": "bun run dev:stack & bun run dev:desktop:wait",
    "test:local": "bash ./local/test-flow.sh",
    "test:local:e2e": "bun test local/local-flow.test.ts",
    "db:generate": "cd packages/db && bun run build",
    "postinstall": "bun run db:generate",
    "dev:turbo": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "turbo run format",
    "docker:build": "turbo run docker:build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "turbo": "^2.1.2",
    "typescript": "^5.6.3"
  }
}
