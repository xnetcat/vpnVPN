# =============================================================================
# vpnVPN Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# This file is used by the deployment script and local development.

# -----------------------------------------------------------------------------
# Environment (staging | production)
# -----------------------------------------------------------------------------
ENVIRONMENT=staging

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Pulumi Configuration
# -----------------------------------------------------------------------------
PULUMI_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Database (Neon for production, local Postgres for dev)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/vpnvpn

# -----------------------------------------------------------------------------
# Control Plane Service
# -----------------------------------------------------------------------------
# URL will be the API Gateway endpoint after Lambda deployment
CONTROL_PLANE_API_URL=https://api.vpnvpn.dev
CONTROL_PLANE_API_KEY=your-control-plane-api-key
CONTROL_PLANE_BOOTSTRAP_TOKEN=dummy-token

# -----------------------------------------------------------------------------
# Metrics Service
# -----------------------------------------------------------------------------
# URL will be the API Gateway endpoint after Lambda deployment
METRICS_API_URL=https://metrics.vpnvpn.dev

# -----------------------------------------------------------------------------
# Web App (NextAuth)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=https://staging.vpnvpn.dev
NEXTAUTH_SECRET=your-nextauth-secret

# Public URLs for frontend
NEXT_PUBLIC_API_BASE_URL=https://api.vpnvpn.dev

# -----------------------------------------------------------------------------
# OAuth Providers
# -----------------------------------------------------------------------------
GITHUB_ID=
GITHUB_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=noreply@vpnvpn.dev

# -----------------------------------------------------------------------------
# Stripe Billing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_BASIC=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# -----------------------------------------------------------------------------
# WireGuard Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WG_ENDPOINT=vpn.vpnvpn.dev:51820
NEXT_PUBLIC_WG_SERVER_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Desktop App Configuration
# -----------------------------------------------------------------------------
VITE_VPNVPN_DESKTOP_URL=https://staging.vpnvpn.dev/desktop?desktop=1
VITE_VPNVPN_API_URL=https://staging.vpnvpn.dev

# S3 bucket for desktop app downloads (from Pulumi global stack output)
DESKTOP_S3_BUCKET=vpnvpn-desktop-staging
DESKTOP_BUCKET_URL=https://vpnvpn-desktop-staging.s3.amazonaws.com
NEXT_PUBLIC_DESKTOP_BUCKET_URL=https://vpnvpn-desktop-staging.s3.amazonaws.com

# -----------------------------------------------------------------------------
# Lambda Deployment (S3 bucket for code packages)
# -----------------------------------------------------------------------------
LAMBDA_CODE_BUCKET=vpnvpn-lambda-deployments

# -----------------------------------------------------------------------------
# ECR Repository
# -----------------------------------------------------------------------------
ECR_REPO_NAME=vpnvpn/rust-server

# -----------------------------------------------------------------------------
# VPN Token (for local development and VPN node registration)
# -----------------------------------------------------------------------------
VPN_TOKEN=dummy-token
